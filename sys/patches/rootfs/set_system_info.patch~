Add system info to /etc/profile, set the hostname, show version.
Index: hyperdiver/rootfs/etc/init.d/S21aconfig
===================================================================
--- hyperdiver.orig/rootfs/etc/init.d/S21aconfig
+++ hyperdiver/rootfs/etc/init.d/S21aconfig
@@ -9,6 +9,8 @@ echo 20 > /proc/sys/vm/dirty_ratio
 echo 200 > /proc/sys/vm/vfs_cache_pressure
   
 echo "rootfs compile user:tuzuguo time:2018-08-15 10:37:05"
+macaddr=$(cat /sys/class/net/eth0/address | tr -d ':')
+hostname hyperdiver-$macaddr
 ifconfig lo 127.0.0.1
 ifconfig eth0 192.168.1.99
 #  mount -t nfs -o nolock 192.168.1.63:/home/admin1/work/hi/3531/nfs /home/
Index: hyperdiver/rootfs/etc/profile
===================================================================
--- hyperdiver.orig/rootfs/etc/profile
+++ hyperdiver/rootfs/etc/profile
@@ -32,7 +32,12 @@ MAGENTA="[1;35m"
 CYAN="[1;36m"
 WHITE="[1;37m"
 
-umask 022
+VERSION=$(cat /etc/hd/version)
+MAC=$(cat /sys/class/net/eth0/address)
 
-echo "${GREEN}Welcome to HiLinux.${NORMAL}"
+umask 022
 
+echo "${GREEN}Welcome to HiLinux."
+echo "${BLUE}Hyperdiver ${VERSION}"
+echo "${MAGENTA}MAC: ${MAC}"
+echo "${RED}Roll the katamari.${NORMAL}"
